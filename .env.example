PORT=8787
# Optional. Defaults to http://localhost:${PORT}
LOCAL_BASE_URL=http://localhost:8787

# Microsoft Entra app registration for Power BI/Fabric delegated access.
# Add the delegated Power BI Service and Microsoft Fabric scopes listed in
# README.md. If scopes change after you connect once, reconnect so the token
# includes them.
POWERBI_TENANT_ID=your-tenant-id
POWERBI_CLIENT_ID=your-client-id

# Required. Use the client secret Value from Azure, not the Secret ID.
POWERBI_CLIENT_SECRET=your-client-secret-value

# Optional comma-separated scope overrides. POWERBI_SCOPES can include OpenID
# scopes plus Power BI Service scopes. FABRIC_SCOPES is requested as a separate
# Microsoft Fabric token audience.
# POWERBI_SCOPES=openid,profile,email,offline_access,https://analysis.windows.net/powerbi/api/Workspace.Read.All,https://analysis.windows.net/powerbi/api/Dashboard.Read.All,https://analysis.windows.net/powerbi/api/Report.Read.All,https://analysis.windows.net/powerbi/api/Dataset.ReadWrite.All
# FABRIC_SCOPES=https://api.fabric.microsoft.com/Workspace.Read.All,https://api.fabric.microsoft.com/SemanticModel.Read.All

# Optional XMLA bridge settings. The default bridge path points at the bundled
# .NET project. Writes are disabled unless explicitly enabled.
# XMLA_BRIDGE_PATH=xmla_bridge/PowerBIXmlaBridge/PowerBIXmlaBridge.csproj
# POWERBI_XMLA_TENANT_ALIAS=myorg
# POWERBI_XMLA_ALLOW_WRITES=false
# XMLA_BRIDGE_TIMEOUT_SECONDS=60

# 32-byte key encoded as base64. Generate one with:
# python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=replace-me

# Optional comma-separated workspace IDs or names to hint in docs/UI.
KNOWN_WORKSPACES=
