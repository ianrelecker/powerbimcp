PORT=8787
# Optional. Defaults to http://localhost:${PORT}
LOCAL_BASE_URL=http://localhost:8787

# Microsoft Entra app registration for Power BI REST API access.
# Add the delegated Power BI Service scopes listed in README.md. If scopes
# change after you connect once, reconnect so the token includes them.
POWERBI_TENANT_ID=your-tenant-id
POWERBI_CLIENT_ID=your-client-id

# Required. Use the client secret Value from Azure, not the Secret ID.
POWERBI_CLIENT_SECRET=your-client-secret-value

# Optional comma-separated scope override. Defaults to read-only dashboard,
# workspace, report, and dataset scopes for the Power BI REST API.
# POWERBI_SCOPES=openid,profile,email,offline_access,https://analysis.windows.net/powerbi/api/Workspace.Read.All,https://analysis.windows.net/powerbi/api/Dashboard.Read.All,https://analysis.windows.net/powerbi/api/Report.Read.All,https://analysis.windows.net/powerbi/api/Dataset.Read.All

# 32-byte key encoded as base64. Generate one with:
# python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
TOKEN_ENCRYPTION_KEY=replace-me

# Optional comma-separated workspace IDs or names to hint in docs/UI.
KNOWN_WORKSPACES=
